{
  "name": "adb-battery-graph",
  "version": "1.0.0",
  "description": "Web ADB Battery Graph",
  "scripts": {
    "build": "esbuild src/main.js --bundle --minify --sourcemap --target=es2020 --outfile=web/dist/main.bundle.js",
    "prebuild": "mkdir -p web/dist && cp node_modules/chart.js/dist/chart.umd.js web/dist/chart.js"
  },
  "dependencies": {
    "@yume-chan/adb": "^2.5.1",
    "@yume-chan/adb-credential-web": "^2.1.0",
    "@yume-chan/adb-daemon-webusb": "^2.3.2",
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
